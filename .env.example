# Site URL (canonical base for sitemap and OG metadata)
NEXT_PUBLIC_SITE_URL=https://picktherobot.com

# --- Google Search Console (optional) ---
# HTML tag verification: paste only the content value from Search Console
# (not the full meta tag). Example: abc123XYZ...
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Analytics (optional — leave blank to disable) ---
# If either ID is set, a cookie consent banner appears before scripts load.
# Users must accept analytics before GA4 / Plausible run.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Plausible domain (e.g. picktherobot.com)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Production checklist:
# 1. Set NEXT_PUBLIC_SITE_URL to your live domain
# 2. Add NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION, deploy, then verify in Search Console
# 3. Submit https://picktherobot.com/sitemap.xml in Search Console → Sitemaps
# 4. Enable analytics only after privacy policy is live
# 5. Prefer Plausible for lighter compliance; GA4 needs explicit consent in EU/UK
